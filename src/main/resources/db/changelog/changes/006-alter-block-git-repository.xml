<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="006-alter-block-git-repository" author="zor07">
        <addColumn tableName="block">
            <column name="git_repository_id" type="BIGINT"/>
        </addColumn>

        <update tableName="block">
            <column name="git_repository_id" valueNumeric="1"/>
        </update>

        <addNotNullConstraint tableName="block"
                              columnName="git_repository_id"
                              columnDataType="BIGINT"/>

        <addForeignKeyConstraint baseTableName="block"
                                 baseColumnNames="git_repository_id"
                                 constraintName="fk_block_git_repository"
                                 referencedTableName="git_repository"
                                 referencedColumnNames="id"/>

        <dropColumn tableName="block" columnName="template_repo_name"/>
    </changeSet>

</databaseChangeLog>
