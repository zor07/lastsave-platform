<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="007-create-student-repository" author="zor07">
        <createTable tableName="student_repository">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="student_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="git_repository_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="repo_url" type="VARCHAR(1024)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="student_repository"
                                 baseColumnNames="student_id"
                                 constraintName="fk_student_repository_student"
                                 referencedTableName="students"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="student_repository"
                                 baseColumnNames="git_repository_id"
                                 constraintName="fk_student_repository_git_repository"
                                 referencedTableName="git_repository"
                                 referencedColumnNames="id"/>

        <addUniqueConstraint tableName="student_repository"
                             columnNames="student_id, git_repository_id"
                             constraintName="uq_student_repository"/>
    </changeSet>

</databaseChangeLog>
